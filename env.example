# Copy to the server (e.g. /home/ahad/iptv-proxy/.env) and load from systemd.
# PROXY_TOKEN_SECRET must match Cloudflare Pages (tv-proxy-ui) exactly.

PROXY_BASE=https://proxy.previewcloud.cloud
PROXY_TOKEN_SECRET=replace-with-the-same-secret-as-cloudflare-pages

# MongoDB Atlas connection string (Database → Connect → Drivers → Go).
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority

# Optional database name (default: tv_proxy)
# MONGODB_DB=tv_proxy

# Protect admin /data/* write endpoints. Must match Cloudflare Pages DATA_API_SECRET.
# Generate: openssl rand -base64 48
DATA_API_SECRET=replace-with-the-same-secret-as-cloudflare-pages

PORT=8080
MAX_CONCURRENT=1000
